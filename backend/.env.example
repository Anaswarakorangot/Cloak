# Secret key used for signing JWT tokens. 
# Change this to a secure random string in production!
JWT_SECRET_KEY=cloak_development_secret_key_change_me_in_prod

# The Google Gemini API key used for the AI detection engine
# GEMINI_API_KEY="your_api_key_here"

# Algorithm used for JWT token signing
# JWT_ALGORITHM=HS256

# JWT token expiration time in minutes (default 1 day)
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
